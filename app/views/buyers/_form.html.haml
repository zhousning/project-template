.container-fluid
  .row.justify-content-sm-center
    .col-sm-6
      = form_for @buyer do |f|
        - if @buyer.errors.any?
          #error_explanation
            %h2= "#{pluralize(@buyer.errors.count, "error")} prohibited this buyer from being saved:"
            %ul
              - @buyer.errors.full_messages.each do |msg|
                %li= msg
        .form-group.row
          = f.label "简称", :class => "col-sm-3 col-form-label"
          .col-sm-9
            = f.text_field :alias, :class => "form-control"
        .form-group.row
          = f.label "客户名称", :class => "col-sm-3 col-form-label"
          .col-sm-9
            = f.text_field :name, :class => "form-control"
        .form-group.row
          = f.label "购方税号", :class => "col-sm-3 col-form-label"
          .col-sm-9
            = f.text_field :duty_paragraph, :class => "form-control"
        .form-group.row
          = f.label "购方银行账号", :class => "col-sm-3 col-form-label"
          .col-sm-9
            = f.text_field :account, :class => "form-control"
        .form-group.row
          = f.label "购方地址电话", :class => "col-sm-3 col-form-label"
          .col-sm-9
            = f.text_field :phone, :class => "form-control"
        .form-group.row
          = f.label "备注", :class => "col-sm-3 col-form-label"
          .col-sm-9
            = f.text_field :remark, :class => "form-control"
        .form-group.row
          = f.label "复核人", :class => "col-sm-3 col-form-label"
          .col-sm-9
            = f.text_field :checker, :class => "form-control"
        .form-group.row
          = f.label "收款人", :class => "col-sm-3 col-form-label"
          .col-sm-9
            = f.text_field :payee, :class => "form-control"
        .form-group.row
          = f.label "截图附件", :class => "col-sm-3 control-label"
          .col-sm-9
            = f.fields_for :enclosures do |enclosure|
              = render 'enclosure_fields', f: enclosure
            .links
              = link_to_add_association "添加文件", f, :enclosures, :class => "btn btn-success"
        .form-group.row
          .col-sm-3.offset-sm-2
            = f.submit '保存', :class => "btn btn-success"
          .col-sm-3.offset-sm-1
            = link_to '返回', buyers_path, :class => "btn btn-danger"
